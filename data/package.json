  "homepage": "https://github.com/gbicou/countries-server",
  "keywords": [
    "graphql",
    "typescript"
  ],
  "author": "Benjamin VIELLARD <bicou@bicou.com>",
  "license": "MIT",
  "repository": "github:gbicou/countries-server",
